# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*.local
.env

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
/playwright-report
/test-results
/playwright/.cache

# Claude Code session data — never commit
.claude/

# Twitter import media — reproducible from the archive via
# scripts/apply-twitter-import.mjs. Tracking 100+ MB of mp4s in git
# bloats every clone and we have the script to regenerate.
public/imports/

# Local Netlify folder
.netlify

# Serwist generates these on every build (see app/sw.ts).
public/sw.js
public/sw.js.map
public/swe-worker-*.js

# Lighthouse CI report dump — populated by `npm run lighthouse` and
# uploaded to temporary public storage (see .lighthouserc.json).
# The HTML / JSON files are reports for that single run, not source.
/.lighthouseci

