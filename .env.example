# Copy to .env.local and edit. Anything starting with NEXT_PUBLIC_ is
# bundled into the client — never put real secrets in those.

# Public site URL. Used by sitemap.xml, robots.txt, OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Demo admin credentials for the mock auth flow. Replace with values
# specific to your deployment, or — preferably — replace the mock auth
# entirely by wiring lib/repo.ts to a real auth provider. Anyone with
# access to the bundle can read these.
NEXT_PUBLIC_ADMIN_EMAIL=admin@taote.pocus
NEXT_PUBLIC_ADMIN_PASSWORD=admin123
