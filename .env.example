# Copy to .env.local and edit. Anything starting with NEXT_PUBLIC_ is
# bundled into the client — never put real secrets in those.
#
# All values below are optional. Missing values fall back to safe demo
# defaults (localStorage backend, no Sentry, no Firebase) — the app
# runs out of the box with `npm install && npm run dev`.

# ─── Site ────────────────────────────────────────────────────────────────────
# Public site URL. Used by sitemap.xml, robots.txt, OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Demo admin (mock auth — only used when Firebase is NOT configured) ─────
# Replace with values specific to your deployment, or — preferably — replace
# the mock auth entirely by configuring Firebase below. Anyone with access
# to the bundle can read these.
NEXT_PUBLIC_ADMIN_EMAIL=admin@taote.pocus
NEXT_PUBLIC_ADMIN_PASSWORD=admin123

# Dev-time admin auto-login. Set to "1" in .env.local to skip the login
# modal entirely — useful while editing the catalog. Hard-disabled in
# production builds (lib/env.ts) so a leaked env can't open admin to
# the public.
NEXT_PUBLIC_ADMIN_BYPASS=0

# ─── Server session (HMAC secret for Server Actions auth) ────────────────────
# Signs the httpOnly cookie that authorizes calls into app/actions/db.ts.
# REQUIRED in production: when unset, every Server Action returns
# `auth_required` and the dual-write mirror fails. Generate a value with:
#
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
#
# In dev (NODE_ENV !== "production") an unset value is replaced by a
# transient per-process random secret — sessions reset on every server
# restart, which is fine locally. NEVER commit a real value.
AUTH_SECRET=

# ─── Firebase (real auth + Firestore persistence) ───────────────────────────
# Setting all six values flips IS_FIREBASE_ENABLED to true and the repo
# facade switches to the network backend. See ADR-0004.
#
# Setup steps:
#   1. Create a Firebase project at https://console.firebase.google.com
#   2. Authentication → Sign-in method → enable Email/Password
#   3. Authentication → Users → manually create the admin account with
#      the email matching NEXT_PUBLIC_ADMIN_EMAIL above
#   4. Firestore Database → create in production mode
#   5. Project settings → General → "Your apps" → register a Web app and
#      copy the six config values below
#   6. Apply the Firestore security rules in `firestore.rules` (TODO)
#
# These values are NOT secrets — Firebase API keys are public by design;
# Firestore Security Rules are the access control. Safe to commit to a
# private repo, but do NOT commit your .env.local.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Sentry (error reporting + performance monitoring, optional) ────────────
# Setting NEXT_PUBLIC_SENTRY_DSN activates the Sentry SDK. See ADR-0005.
#
# Setup steps:
#   1. Create an account at https://sentry.io
#   2. New project → Next.js platform
#   3. Copy the DSN from Project Settings → Client Keys
#
# Server-only vars (NOT prefixed NEXT_PUBLIC_) — these enable sourcemap
# upload during the production build. Without them, builds still succeed
# but stack traces in Sentry stay minified.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=development
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
