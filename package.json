{
  "name": "taote-pocus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:mutation": "stryker run",
    "analyze": "cross-env ANALYZE=true next build",
    "size:check": "node scripts/bundle-budget.mjs",
    "size:update": "node scripts/bundle-budget.mjs --update",
    "optimize:media": "node scripts/optimize-media.mjs",
    "lighthouse": "lhci autorun",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@clerk/localizations": "^4.6.5",
    "@clerk/nextjs": "^7.3.6",
    "@google/genai": "^2.4.0",
    "@netlify/blobs": "^10.7.8",
    "@netlify/database": "^1.0.0",
    "@sentry/nextjs": "^10.53.1",
    "@serwist/next": "^9.5.11",
    "firebase": "^12.13.0",
    "next": "^16.2.4",
    "openai": "^6.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serwist": "^9.5.10"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead",
    "not op_mini all",
    "not IE 11"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.6",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.5"
  }
}
